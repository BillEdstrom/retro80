{
  "name": "retro-basic",
  "version": "0.44.0",
  "description": "Retro80 — an interactive vintage MS-BASIC interpreter for the desktop.",
  "main": "./out/main/index.js",
  "author": "William Edstrom",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "prebuild": "node scripts/bump-build.mjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "node --import tsx --test src/renderer/src/basic/*.test.ts",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:mac:dir": "npm run build && electron-builder --mac --dir"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@micropython/micropython-webassembly-pyscript": "^1.28.0-6",
    "@sentry/electron": "^7.13.0",
    "electron-updater": "^6.8.9",
    "trs80-base": "^2.3.1",
    "trs80-cassette": "^2.3.1",
    "trs80-emulator-web": "^2.3.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "opentype.js": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "wrangler": "^4.103.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BillEdstrom/retro80.git"
  }
}
